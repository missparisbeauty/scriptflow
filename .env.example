# 本機開發複製成 .env，prod 從 GCP Secret Manager 掛載
# .env 已在 .gitignore，永遠不要 commit 真的密碼進 git

DEBUG=false

# GCP
GCP_PROJECT_ID=seo-mpb

# Session 簽章用，至少 32 bytes 隨機（≥256 bit）
SF_SESSION_SECRET=

# 管理員登入密碼（前端表單用）
SF_ADMIN_PASSWORD=

# OpenAI API Key（GPT-5-mini 文字 + gpt-image-1 圖像，共用一把）
SF_OPENAI_API_KEY=

# 爬取輔助服務 credential（暫可留空走 mock）
SF_CRAWLER_CREDENTIAL=

# Crawler backend: mock / tikwm / apify. Leave empty for auto mode.
CRAWLER_BACKEND=apify
SF_APIFY_TOKEN=
APIFY_ACTOR_DOUYIN=clockworks/free-tiktok-scraper
APIFY_ACTOR_XIAOHONGSHU=zen-studio/rednote-search-scraper
APIFY_ACTOR_XIAOHONGSHU_PREVIEW=dltik/rednote-xiaohongshu-scraper
APIFY_ACTOR_THREADS=
SF_XHS_COOKIES=
